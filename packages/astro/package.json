{
  "name": "@faircopy/astro",
  "version": "1.0.2",
  "description": "Astro adapter for faircopy — extracts prose from .astro files with source maps",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "echo 'no tests'",
    "prepublishOnly": "pnpm run build"
  },
  "dependencies": {
    "@astrojs/compiler": "^2.13.0",
    "@faircopy/core": "workspace:*"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/node": "^22.0.0",
    "tsup": "^8.4.0",
    "typescript": "^5.8.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "author": "omniaura"
}
