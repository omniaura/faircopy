{
  "name": "@faircopy/cli",
  "version": "1.0.5",
  "description": "CLI for faircopy — faircopy lint, fix, explain",
  "type": "module",
  "bin": {
    "faircopy": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./cli": {
      "import": "./dist/cli.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "echo 'no tests yet'",
    "prepublishOnly": "pnpm run build"
  },
  "dependencies": {
    "@faircopy/core": "workspace:*",
    "cac": "^6.7.14",
    "picocolors": "^1.1.1"
  },
  "peerDependencies": {
    "@faircopy/rules-default": "workspace:*"
  },
  "peerDependenciesMeta": {
    "@faircopy/rules-default": {
      "optional": true
    }
  },
  "devDependencies": {
    "@faircopy/rules-default": "workspace:*",
    "@types/node": "^22.0.0",
    "tsup": "^8.4.0",
    "typescript": "^5.8.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "author": "omniaura",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/omniaura/faircopy.git"
  }
}
