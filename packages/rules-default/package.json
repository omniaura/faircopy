{
  "name": "@faircopy/rules-default",
  "version": "1.4.0",
  "description": "Default ruleset for faircopy: no-em-dash, no-weasel-words, no-rhetorical-scaffolding",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "echo 'no tests'",
    "prepublishOnly": "pnpm run build"
  },
  "dependencies": {
    "@faircopy/core": "workspace:*"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "author": "omniaura",
  "repository": {
    "type": "git",
    "url": "https://github.com/omniaura/faircopy"
  }
}
