    "tsup": "^8.5.1",
    "typescript": "^6.0.3"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "author": "omniaura",
  "repository": {
    "type": "git",
    "url": "https://github.com/omniaura/faircopy"
  }
