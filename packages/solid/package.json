{
  "name": "@faircopy/solid",
  "version": "1.3.0",
  "description": "SolidJS adapter for faircopy — extracts prose from .tsx and .jsx files",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "echo 'no tests'",
    "prepublishOnly": "pnpm run build"
  },
  "dependencies": {
    "@babel/parser": "^7.29.2",
    "@babel/types": "^7.29.0",
    "@faircopy/core": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/omniaura/faircopy"
  },
  "license": "MIT",
  "author": "omniaura"
}
